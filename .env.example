# Network + wallet
ROBINHOOD_CHAIN_NETWORK=testnet          # mainnet | testnet
ROBINHOOD_CHAIN_PRIVATE_KEY=             # 0x-prefixed 32-byte hex key. Omit for read-only/dry-run use.
LIVE=                                    # set to 1 to allow real, funded transactions. Unset = dry-run/preflight only.
ACKNOWLEDGE_LAUNCH_RESPONSIBILITY=       # set to 1 to affirm you accept responsibility for launches made with LIVE=1

# Hard caps (see README "Safety" section)
MAX_LAUNCHES_PER_DAY=3
MAX_SEED_USDG=50

# Concept engine — bring your own key, either works, both optional
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CONCEPT_LLM_PROVIDER=                    # openai | anthropic — omit to auto-pick whichever key is set
CONCEPT_LLM_MODEL=                       # omit for the built-in default per provider

# Operator-specific safety
HOOD_LAUNCHER_PERSON_DENYLIST=           # comma-separated names to always refuse, beyond the built-in trademark list

# Autonomous mode
AUTO_APPROVE=                            # set to 1 to execute proposals without a manual approve step
AUTO_RAIL=noxa                           # noxa | odyssey | direct
AUTO_ODYSSEY_VARIANT=instant             # instant | bonding
AUTO_INITIAL_BUY_ETH=0
AUTO_DIRECT_SEED_ETH=0.01
AUTO_NARRATIVE_WINDOW_HOURS=24

# Storage + service
HOOD_LAUNCHER_DATA_DIR=.hood-launcher    # ledger, proposals, KILL sentinel file
PORT=8787                                # HTTP API port
